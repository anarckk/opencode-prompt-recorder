{
  "name": "opencode-prompt-recorder",
  "version": "1.0.0",
  "description": "OpenCode plugin for recording user prompts. Automatically saves user messages to a local file system with organized directory structure.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun build index.ts --outdir dist --target node",
    "prepublishOnly": "bun run build",
    "test": "bun test"
  },
  "keywords": [
    "opencode",
    "prompt",
    "recording",
    "logging",
    "plugin",
    "llm",
    "ai",
    "audit"
  ],
  "author": "OpenCode Community",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/H2Shami/opencode-prompt-recorder.git"
  },
  "bugs": {
    "url": "https://github.com/H2Shami/opencode-prompt-recorder/issues"
  },
  "homepage": "https://github.com/H2Shami/opencode-prompt-recorder#readme",
  "peerDependencies": {
    "@opencode-ai/plugin": ">=0.15.0",
    "typescript": ">=5.0.0"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^0.15.0",
    "@types/bun": "^1.3.1",
    "typescript": "^5.9.3"
  }
}
